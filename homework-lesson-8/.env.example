# Copy to .env in this folder — do not commit real keys.
OPENAI_API_KEY=sk-your-api-key-here
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large

DATA_DIR=data
INDEX_DIR=index
CHROMA_COLLECTION=lesson8_kb

CHUNK_SIZE=1024
CHUNK_OVERLAP=200
RERANKER_MODEL=BAAI/bge-reranker-base
RETRIEVAL_VECTOR_K=10
RETRIEVAL_BM25_K=10
RETRIEVAL_FUSION_TOP_N=20
RERANK_TOP_N=5
MAX_KNOWLEDGE_CHARS=8000

MAX_SEARCH_RESULTS=5
MAX_URL_CONTENT_LENGTH=5000
MAX_ITERATIONS=16
OUTPUT_DIR=output
REQUEST_TIMEOUT=90

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# true | false — вимкнути всі логи (NullHandler)
LOG_ENABLED=true
# stderr | file | both — екран (stderr), файл, або обидва
LOG_DESTINATION=stderr
# Шлях до файлу логів (відносно цієї папки проєкту, якщо не абсолютний)
LOG_FILE=logs/lesson8.log
