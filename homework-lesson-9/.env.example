OPENAI_API_KEY=sk-your-api-key-here
MODEL_NAME=gpt-4o-mini
SUPERVISOR_MODEL_NAME=gpt-5.4-mini
PLANNER_MODEL_NAME=gpt-5.4-mini
RESEARCH_MODEL_NAME=gpt-5.4-mini
CRITIC_MODEL_NAME=gpt-5.4

DATA_DIR=data
INDEX_DIR=index
CHROMA_COLLECTION=lesson9_kb

SEARCH_MCP_URL=http://127.0.0.1:8901/mcp
REPORT_MCP_URL=http://127.0.0.1:8902/mcp
ACP_BASE_URL=http://127.0.0.1:8903
# Таймаут у секундах на HTTP-запит Supervisor → ACP /runs (на сервері LLM + MCP, по дефорту 5 с)
ACP_HTTP_TIMEOUT=600

SEARCH_MCP_PORT=8901
REPORT_MCP_PORT=8902
ACP_PORT=8903

MAX_ITERATIONS=50
MAX_SEARCH_RESULTS=3
OUTPUT_DIR=output

LOG_LEVEL=INFO
LOG_ENABLED=true
LOG_DESTINATION=stderr
LOG_FILE=logs/lesson9.log
