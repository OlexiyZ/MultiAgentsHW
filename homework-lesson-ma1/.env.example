# Copy to .env — do not commit real keys.
OPENAI_API_KEY=sk-your-api-key-here
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large

# Use the same flavour as your last ingest: langchain | llama
KNOWLEDGE_FLAVOUR=langchain

DATA_DIR=data
INDEX_DIR=index
CHROMA_COLLECTION=lesson5_kb

CHUNK_SIZE=1024
CHUNK_OVERLAP=200
RERANKER_MODEL=BAAI/bge-reranker-base
RETRIEVAL_VECTOR_K=10
RETRIEVAL_BM25_K=10
RETRIEVAL_FUSION_TOP_N=20
RERANK_TOP_N=5
MAX_KNOWLEDGE_CHARS=8000

MAX_SEARCH_RESULTS=5
MAX_URL_CONTENT_LENGTH=5000
MAX_ITERATIONS=12
OUTPUT_DIR=output
REQUEST_TIMEOUT=60
