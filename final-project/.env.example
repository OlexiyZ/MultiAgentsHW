# Copy to .env in this folder — do not commit real keys.
OPENAI_API_KEY=sk-your-api-key-here
MODEL_NAME=gpt-4o-mini
SUPERVISOR_MODEL_NAME=gpt-5.4-mini
PLANNER_MODEL_NAME=gpt-5.4-mini
RESEARCH_MODEL_NAME=gpt-5.4-mini
CRITIC_MODEL_NAME=gpt-5.4
EMBEDDING_MODEL=text-embedding-3-large

LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
LANGFUSE_DEFAULT_TAGS="mas,final-project"
LANGFUSE_PROMPT_LABEL=production
SUPERVISOR_PROMPT_NAME="final-project/supervisor-system"
PLANNER_PROMPT_NAME="final-project/planner-system"
RESEARCH_PROMPT_NAME="final-project/research-system"
CRITIC_PROMPT_NAME="final-project/critic-system"

DATA_DIR=data
INDEX_DIR=index
CHROMA_COLLECTION=final-project_kb
INGEST_REBUILD_INDEX=true
INGEST_TAG_FILTERS=issuer_match:nbu,issuer_match:ema

CHUNK_SIZE=1024
CHUNK_OVERLAP=200
RERANKER_MODEL=BAAI/bge-reranker-base
RETRIEVAL_VECTOR_K=10
RETRIEVAL_BM25_K=10
RETRIEVAL_FUSION_TOP_N=20
RERANK_TOP_N=5
MAX_KNOWLEDGE_CHARS=8000

MAX_SEARCH_RESULTS=5
MAX_URL_CONTENT_LENGTH=5000
MAX_NORMATIVE_DOC_CHARS=500000
NORMATIVE_EXCERPT_WINDOW=2500
NORMATIVE_EXCERPT_MAX_FRAGMENTS=8
MAX_ITERATIONS=16
OUTPUT_DIR=output
REQUEST_TIMEOUT=90

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# true | false — вимкнути всі логи (NullHandler)
LOG_ENABLED=true
# stderr | file | both — екран (stderr), файл, або обидва
LOG_DESTINATION=stderr
# Шлях до файлу логів (відносно цієї папки проєкту, якщо не абсолютний)
LOG_FILE=logs/lesson8.log

# Optional live-test flag. Not required for normal main.py / ingest.py runs.
RUN_LIVE_PIPELINE=0
